  },
  "assist": {
    "enabled": true,
    "includes": ["**"],
    "actions": {
      "source": {
        "noDuplicateClasses": "on",
        "organizeImports": "on",
        "useSortedAttributes": "on",
        "useSortedInterfaceMembers": "off",
        "useSortedKeys": "off",
        "useSortedProperties": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "includes": ["**"],
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "expand": "auto",
    "trailingNewline": true,
    "useEditorconfig": false
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": false,
      "jsxEverywhere": false,
      "gritMetavariables": false
    },
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 80,
      "bracketSameLine": false,
      "bracketSpacing": true,
      "attributePosition": "auto",
      "expand": "auto",
      "operatorLinebreak": "after",
      "trailingNewline": true
    },
    "globals": [],
    "jsxRuntime": "transparent",
    "linter": { "enabled": true },
    "assist": { "enabled": true },
    "experimentalEmbeddedSnippetsEnabled": false
  },
  "json": {
    "parser": {
      "allowComments": false,
      "allowTrailingCommas": false
    },
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 80,
      "trailingCommas": "none",
      "bracketSpacing": true,
      "enabled": true,
      "expand": "auto",
      "trailingNewline": true
    },
    "linter": { "enabled": true },
    "assist": { "enabled": true }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": false,
      "allowWrongLineComments": false
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineEnding": "lf",
      "lineWidth": 80,
      "quoteStyle": "double",
      "trailingNewline": true
    },
    "linter": { "enabled": true },
    "assist": { "enabled": true },
    "globals": null
  },
  "graphql": {
    "formatter": { "enabled": false },
    "linter": { "enabled": false },
    "assist": { "enabled": false }
  },
  "grit": {
    "formatter": { "enabled": false },
    "linter": { "enabled": false },
    "assist": { "enabled": false }
  },
  "html": {
    "experimentalFullSupportEnabled": false,
    "parser": { "interpolation": false },
    "formatter": { "enabled": false },
    "linter": { "enabled": false },
    "assist": { "enabled": false }
  }
}
