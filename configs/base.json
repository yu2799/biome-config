        "noUnknownPseudoElement": "error",
        "noUnknownTypeSelector": "error",
        "noUnknownUnit": "error",
        "noUnmatchableAnbSelector": "error",
        "noUnreachable": "error",
        "noUnreachableSuper": "error",
        "noUnsafeFinally": "error",
        "noUnsafeOptionalChaining": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedLabels": "error",
        "noUnusedPrivateClassMembers": "error",
        "noUnusedVariables": "error",
        "noVoidElementsWithChildren": "error",
        "noVoidTypeReturn": "error",
        "useIsNan": "error",
        "useParseIntRadix": "error",
        "useSingleJsDocAsterisk": "error",
        "useValidForDirection": "error",
        "useValidTypeof": "error",
        "useYield": "error"
      },
      "nursery": {
        "noAmbiguousAnchorText": "error",
        "noContinue": "error",
        "noDeprecatedMediaType": "error",
        "noDivRegex": "error",
        "noDuplicateAttributes": "error",
        "noDuplicateEnumValues": "error",
        "noDuplicateSelectors": "error",
        "noEmptyObjectKeys": "error",
        "noEqualsToNull": "error",
        "noExcessiveClassesPerFile": "error",
        "noExcessiveLinesPerFile": "error",
        "noExcessiveNestedCallbacks": "error",
        "noExcessiveSelectorClasses": "error",
        "noFloatingClasses": "error",
        "noForIn": "error",
        "noHexColors": "error",
        "noImpliedEval": "error",
        "noIncrementDecrement": "error",
        "noInlineStyles": "error",
        "noLoopFunc": "error",
        "noMultiAssign": "error",
        "noMultiStr": "error",
        "noNestedPromises": "error",
        "noParametersOnlyUsedInRecursion": "error",
        "noProto": "error",
        "noRedundantDefaultExport": "error",
